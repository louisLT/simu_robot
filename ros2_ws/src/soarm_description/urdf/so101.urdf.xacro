<?xml version="1.0" encoding="utf-8"?>
<!-- SO-ARM101 XACRO: wraps the original URDF with ros2_control + Gazebo plugins -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="so101">

  <!-- ================================================================== -->
  <!-- Materials                                                          -->
  <!-- ================================================================== -->
  <material name="3d_printed">
    <color rgba="1.0 0.82 0.12 1.0"/>
  </material>
  <material name="sts3215">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ================================================================== -->
  <!-- Mesh path macro                                                    -->
  <!-- ================================================================== -->
  <xacro:property name="mesh_path" value="package://soarm_description/meshes"/>

  <!-- ================================================================== -->
  <!-- World fixation (screwed to the table)                              -->
  <!-- ================================================================== -->
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- ================================================================== -->
  <!-- Links                                                              -->
  <!-- ================================================================== -->

  <!-- Base -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0137179 -5.19711e-05 0.0334843" rpy="0 0 0"/>
      <mass value="0.147"/>
      <inertia ixx="0.000114686" ixy="-4.59787e-07" ixz="4.97151e-06"
               iyy="0.000136117" iyz="9.75275e-08" izz="0.000130364"/>
    </inertial>
    <visual>
      <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_path}/base_motor_holder_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_path}/base_motor_holder_so101_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.00636471 0 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_path}/base_so101_v2.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.00636471 0 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_path}/base_so101_v2.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.0263353 0 0.0437" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0.0263353 0 0.0437" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_path}/waveshare_mounting_plate_so101_v2.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_path}/waveshare_mounting_plate_so101_v2.stl"/></geometry>
    </collision>
  </link>

  <!-- Shoulder -->
  <link name="shoulder_link">
    <inertial>
      <origin xyz="-0.0307604 -1.66727e-05 -0.0252713" rpy="0 0 0"/>
      <mass value="0.100006"/>
      <inertia ixx="8.3759e-05" ixy="7.55525e-08" ixz="-1.16342e-06"
               iyy="8.10403e-05" iyz="1.54663e-07" izz="2.39783e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/motor_holder_so101_base_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/motor_holder_so101_base_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_path}/rotation_pitch_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_path}/rotation_pitch_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- Upper arm -->
  <link name="upper_arm_link">
    <inertial>
      <origin xyz="-0.0898471 -0.00838224 0.0184089" rpy="0 0 0"/>
      <mass value="0.103"/>
      <inertia ixx="4.08002e-05" ixy="-1.97819e-05" ixz="-4.03016e-08"
               iyy="0.000147318" iyz="8.97326e-09" izz="0.000142487"/>
    </inertial>
    <visual>
      <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 0 -1.5708"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 0 -1.5708"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/upper_arm_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/upper_arm_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- Lower arm -->
  <link name="lower_arm_link">
    <inertial>
      <origin xyz="-0.0980701 0.00324376 0.0182831" rpy="0 0 0"/>
      <mass value="0.104"/>
      <inertia ixx="2.87438e-05" ixy="7.41152e-06" ixz="1.26409e-06"
               iyy="0.000159844" iyz="-4.90188e-08" izz="0.00014529"/>
    </inertial>
    <visual>
      <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/under_arm_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/under_arm_so101_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/motor_holder_so101_wrist_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/motor_holder_so101_wrist_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- Wrist -->
  <link name="wrist_link">
    <inertial>
      <origin xyz="-0.000103312 -0.0386143 0.0281156" rpy="0 0 0"/>
      <mass value="0.079"/>
      <inertia ixx="3.68263e-05" ixy="1.7893e-08" ixz="-5.28128e-08"
               iyy="2.5391e-05" iyz="3.6412e-06" izz="2.1e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_no_horn_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_no_horn_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/wrist_roll_pitch_so101_v2.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_path}/wrist_roll_pitch_so101_v2.stl"/></geometry>
    </collision>
  </link>

  <!-- Gripper -->
  <link name="gripper_link">
    <inertial>
      <origin xyz="0.000213627 0.000245138 -0.025187" rpy="0 0 0"/>
      <mass value="0.087"/>
      <inertia ixx="2.75087e-05" ixy="-3.35241e-07" ixz="-5.7352e-06"
               iyy="4.33657e-05" iyz="-5.17847e-08" izz="3.45059e-05"/>
    </inertial>
    <visual>
      <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_path}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 -0.000218214 0.000949706" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/wrist_roll_follower_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 -0.000218214 0.000949706" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_path}/wrist_roll_follower_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- Gripper frame (dummy) -->
  <link name="gripper_frame_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1e-9"/>
      <inertia ixx="1e-12" ixy="0" ixz="0" iyy="1e-12" iyz="0" izz="1e-12"/>
    </inertial>
  </link>

  <!-- Moving jaw -->
  <link name="moving_jaw_link">
    <inertial>
      <origin xyz="-0.00157495 -0.0300244 0.0192755" rpy="0 0 0"/>
      <mass value="0.012"/>
      <inertia ixx="6.61427e-06" ixy="-3.19807e-07" ixz="-5.90717e-09"
               iyy="1.89032e-06" iyz="-1.09945e-07" izz="5.28738e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0189" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/moving_jaw_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0189" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/moving_jaw_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- ================================================================== -->
  <!-- Joints                                                             -->
  <!-- ================================================================== -->

  <joint name="shoulder_pan" type="revolute">
    <origin xyz="0.0388353 0 0.0624" rpy="3.14159 0 -3.14159"/>
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.91986" upper="1.91986"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="shoulder_lift" type="revolute">
    <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.74533" upper="1.74533"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="elbow_flex" type="revolute">
    <origin xyz="-0.11257 -0.028 0" rpy="0 0 1.5708"/>
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.69" upper="1.69"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="wrist_flex" type="revolute">
    <origin xyz="-0.1349 0.0052 0" rpy="0 0 -1.5708"/>
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.65806" upper="1.65806"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="wrist_roll" type="revolute">
    <origin xyz="0 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-2.74385" upper="2.84121"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="gripper" type="revolute">
    <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 0 0"/>
    <parent link="gripper_link"/>
    <child link="moving_jaw_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-0.174533" upper="1.74533"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="gripper_frame_joint" type="fixed">
    <origin xyz="-0.0079 -0.000218121 -0.0981274" rpy="0 3.14159 0"/>
    <parent link="gripper_link"/>
    <child link="gripper_frame_link"/>
  </joint>

  <!-- ================================================================== -->
  <!-- ros2_control hardware interface                                    -->
  <!-- ================================================================== -->
  <ros2_control name="so101_control" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="shoulder_pan">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder_lift">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow_flex">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_flex">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_roll">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ================================================================== -->
  <!-- Gazebo ros2_control plugin                                         -->
  <!-- ================================================================== -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find soarm_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ================================================================== -->
  <!-- Gazebo material colors                                             -->
  <!-- ================================================================== -->
  <gazebo reference="base_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="shoulder_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="upper_arm_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="lower_arm_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="wrist_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="gripper_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>
  <gazebo reference="moving_jaw_link">
    <visual><material><ambient>1.0 0.82 0.12 1</ambient><diffuse>1.0 0.82 0.12 1</diffuse></material></visual>
  </gazebo>

</robot>
